{
  "name": "@khub-ai/knowledge-fabric",
  "version": "0.0.1",
  "private": true,
  "description": "KHUB Knowledge Fabric — a knowledge store that learns from your conversations, persists across sessions and agents, and stays on your machine — inspectable and portable by design.",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./types": "./src/types.ts",
    "./extract": "./src/extract.ts",
    "./pipeline": "./src/pipeline.ts",
    "./store": "./src/store.ts",
    "./tools": "./src/tools.ts",
    "./hooks": "./src/hooks.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "openclaw": ">=2026.1.26"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
